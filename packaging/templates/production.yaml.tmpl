server:
  host: "127.0.0.1"
  port: 8080
  enable_tls: false   # TLS terminates at nginx, non nel backend

database:
  # Generato da install.sh (password per-istanza). Usare 127.0.0.1, NON localhost.
  url: "postgresql://vlnman:@@DB_PASSWORD@@@127.0.0.1:5432/vulnerability_manager"
  max_connections: 30
  connection_timeout_seconds: 10
  idle_timeout_seconds: 600
  max_lifetime_seconds: 1800

auth:
  # JWT secret generato per-istanza da install.sh.
  secret: "@@JWT_SECRET@@"
  token_duration_hours: 8
  password:
    min_length: 12
    max_length: 128
    require_uppercase: true
    require_lowercase: true
    require_numbers: true
    require_special_chars: true
    special_chars: "!@#$%^&*()_+-=[]{}|;:,.<>?"
    prevent_common_password: true

security:
  cors:
    enabled: true
    # DEVE combaciare con l'origin esatto usato dal browser (schema+host+porta).
    # Impostato da install.sh sull'IP/host rilevato. Se l'IP cambia (DHCP),
    # aggiorna questa lista e riavvia: sudo systemctl restart sentinelcore
    allowed_origins:
      - "http://@@SERVER_NAME@@"
  csrf:
    enabled: true
    secure_cookie: false   # true solo se servi in HTTPS
  cookies:
    secure: false          # true solo se servi in HTTPS
    same_site: "Strict"

plugins:
  directory: "./plugins"
  enabled: false

network:
  interface: "@@NET_IFACE@@"   # NIC rilevata da install.sh (per il discovery)
  default_scan_timeout: 500
  max_scan_workers: 50

log:
  level: "info"
  file: null
